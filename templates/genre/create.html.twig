{% extends 'base.html.twig' %}

{% block title %}Ajouter une catégorie{% endblock %}

{% block body %}
<div class="genres-container">
    <form method="POST" action="{{ path('app_genre_create') }}">
        <div class="genres-header">
            <h2>Ajouter une catégorie</h2>
            <input type="text" name="name" class="search-input" 
                placeholder="Nom de la catégorie" required>
        </div>

        <div class="btn-back-container">
            <button type="submit" class="btn-submit">💾 Enregistrer</button>
            <a href="{{ path('app_genre_index') }}" class="btn-back">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}