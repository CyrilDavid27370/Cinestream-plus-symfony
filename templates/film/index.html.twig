{% extends 'base.html.twig' %}

{% block title %}Ma Vidéothèque{% endblock %}

{% block body %}
<main>
    <div class="filters">
        <button class="active">Tous les films</button>
    
    {% for genre in genres %}
        <button>{{ genre.name }}</button>
    {% endfor %}
    
    <button>n/c</button>
    <button>👁️</button>
    <button>🕒</button>
    </div>
    
    <div class="films-grid">
        {% for film in films %}
            <a href="#" class="card-link">
                <div class="card">
                    {% if film.posterPath %}
                        <img src="https://image.tmdb.org/t/p/w500{{ film.posterPath }}" alt="{{ film.title }}">
                    {% else %}
                        <div class="no-poster">🎥</div>
                    {% endif %}
                    
                    <div class="card-title">{{ film.title }}</div>
                    <div class="card-meta">
                        📅 {{ film.releaseDate }} 
                        {% if film.isWatched %}👁️{% else %}🕒{% endif %}
                    </div>
                </div>
            </a>
        {% else %}
            <p class="empty-message">Aucun film dans la vidéothèque.</p>
        {% endfor %}
    </div>
</main>
{% endblock %}