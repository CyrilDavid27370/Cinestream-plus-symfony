{% extends 'base.html.twig' %}

{% block title %}Ma Vidéothèque{% endblock %}

{% block body %}
<main>
    <div class="filters">
    <button class="{{ currentGenre is null ? 'active' : '' }}">
        <a href="{{ path('app_film_index') }}">Tous les films</a>
    </button>

    {% for genre in genres %}
        <button class="{{ currentGenre == genre.id ? 'active' : '' }}">
            <a href="{{ path('app_film_index', {'genre': genre.id}) }}">{{ genre.name }}</a>
        </button>
    {% endfor %}

        <button>n/c</button>
        <button class="{{ currentWatched == '1' ? 'active' : '' }}">
        <a href="{{ path('app_film_index', {'watched': '1'}) }}">👁️</a>
        </button>
        <button class="{{ currentWatched == '0' ? 'active' : '' }}">
        <a href="{{ path('app_film_index', {'watched': '0'}) }}">🕒</a>
        </button>
    </div>
    
    <div class="films-grid">
        {% for film in films %}
            <a href="{{ path('app_film_show', {'id': film.id}) }}" class="card-link">
                <div class="card">
                    {% if film.posterPath %}
                        <img src="https://image.tmdb.org/t/p/w500{{ film.posterPath }}" alt="{{ film.title }}">
                    {% else %}
                        <div class="no-poster">🎥</div>
                    {% endif %}
                    
                    <div class="card-title">{{ film.title }}</div>
                    <div class="card-meta">
                        📅 {{ film.releaseDate }} 
                        {% if film.isWatched %}👁️{% else %}🕒{% endif %}
                    </div>
                </div>
            </a>
        {% else %}
            <p class="empty-message">Aucun film dans la vidéothèque.</p>
        {% endfor %}
    </div>
</main>
{% endblock %}